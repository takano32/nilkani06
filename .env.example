SLACK_BOT_TOKEN=xoxb-...        # Slack Bot Token (OAuth & Permissions)
SLACK_APP_TOKEN=xapp-...        # Slack App-Level Token (Socket Mode)
SLACK_NOTIFY_CHANNEL=C...       # 起動通知を送るチャンネルID
GROQ_API_KEY=gsk_...            # Groq API Key (console.groq.com で取得、無料枠あり)
GROQ_MODEL=llama-3.3-70b-versatile  # 省略可、デフォルト llama-3.3-70b-versatile
SYSTEM_PROMPT=あなたは親切で有能なAIアシスタントです。  # 省略可
