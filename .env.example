DISCORD_TOKEN=...                # Discord Bot Token (Developer Portal → Bot)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...  # 起動通知用 Webhook URL（省略可）
OPENAI_API_KEY=sk-...           # OpenAI API Key (platform.openai.com で取得)
OPENAI_MODEL=gpt-4o-mini        # 省略可、デフォルト gpt-4o-mini
SYSTEM_PROMPT=あなたは親切で有能なAIアシスタントです。  # 省略可
MAX_HISTORY=50                  # 省略可、チャンネルごとの最大履歴件数
